{
  "name": "vsc-utils",
  "displayName": "VSC Utils",
  "description": "Integrated browser link routing, hosts adblock, and Explorer browser/file shortcuts.",
  "version": "0.0.4",
  "publisher": "marius-patrik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marius-patrik/vsc-utils.git"
  },
  "bugs": {
    "url": "https://github.com/marius-patrik/vsc-utils/issues"
  },
  "homepage": "https://github.com/marius-patrik/vsc-utils#readme",
  "engines": {
    "vscode": "^1.126.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "browser",
    "integrated-browser",
    "terminal-links",
    "adblock",
    "hosts"
  ],
  "scripts": {
    "check": "node --check extension.js",
    "package": "vsce package --allow-star-activation --out vsc-utils-0.0.4.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:browserUtils.openNewBrowser",
    "onCommand:browserUtils.openClipboardUrl",
    "onCommand:browserUtils.newTextFile",
    "onCommand:browserUtils.adblock.install",
    "onCommand:browserUtils.adblock.remove",
    "onCommand:browserUtils.adblock.status",
    "onCommand:browserUtils.adblock.repairYouTube",
    "onCommand:browserUtils.adblock.copyInstallCommand",
    "onCommand:browserUtils.adblock.openBlocklist",
    "onCommand:browserUtils.adblock.openLog"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "browserUtils.openNewBrowser",
        "title": "New Browser",
        "category": "VSC Utils"
      },
      {
        "command": "browserUtils.openClipboardUrl",
        "title": "Open Clipboard URL in Integrated Browser",
        "category": "VSC Utils"
      },
      {
        "command": "browserUtils.newTextFile",
        "title": "New Text File",
        "category": "VSC Utils"
      },
      {
        "command": "browserUtils.adblock.install",
        "title": "Install/Update Hosts Blocklist",
        "category": "VSC Utils Adblock"
      },
      {
        "command": "browserUtils.adblock.remove",
        "title": "Remove Hosts Blocklist",
        "category": "VSC Utils Adblock"
      },
      {
        "command": "browserUtils.adblock.status",
        "title": "Show Status",
        "category": "VSC Utils Adblock"
      },
      {
        "command": "browserUtils.adblock.repairYouTube",
        "title": "Repair YouTube Playback",
        "category": "VSC Utils Adblock"
      },
      {
        "command": "browserUtils.adblock.copyInstallCommand",
        "title": "Copy Admin Install Command",
        "category": "VSC Utils Adblock"
      },
      {
        "command": "browserUtils.adblock.openBlocklist",
        "title": "Open Blocklist",
        "category": "VSC Utils Adblock"
      },
      {
        "command": "browserUtils.adblock.openLog",
        "title": "Open Log",
        "category": "VSC Utils Adblock"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "browserUtils.newTextFile",
          "group": "navigation@85"
        },
        {
          "command": "browserUtils.openNewBrowser",
          "group": "navigation@86"
        }
      ]
    },
    "configuration": {
      "title": "VSC Utils",
      "properties": {
        "vscUtils.handleTerminalLinks": {
          "type": "boolean",
          "default": true,
          "description": "Open terminal links in VS Code's integrated browser."
        },
        "vscUtils.adblock.extraDomains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional domains to block in the Windows hosts file."
        },
        "browserUtils.handleTerminalLinks": {
          "type": "boolean",
          "default": true,
          "deprecationMessage": "Use vscUtils.handleTerminalLinks instead.",
          "description": "Open terminal links in VS Code's integrated browser."
        },
        "browserUtils.adblock.extraDomains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "deprecationMessage": "Use vscUtils.adblock.extraDomains instead.",
          "description": "Additional domains to block in the Windows hosts file."
        }
      }
    }
  }
}
